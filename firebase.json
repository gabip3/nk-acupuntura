{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.md",
      "**/LEIA-ME.txt",
      "textos-site-atual.md"
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|avif|webp|svg)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
      }
    ],
    "cleanUrls": true
  }
}
